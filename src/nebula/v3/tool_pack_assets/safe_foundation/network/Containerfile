FROM kalilinux/kali-last-release@sha256:338e058ffff77cd47f02e1b98696c2f89d924ecf9c177aab63ae4ec405e951cd
ARG NMAP_VERSION
RUN test -n "$NMAP_VERSION" \
    && apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends "nmap=$NMAP_VERSION" \
    && groupadd --gid 10001 nebula \
    && useradd --uid 10001 --gid 10001 --no-create-home --home-dir /nonexistent --shell /usr/sbin/nologin nebula \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /var/cache/apt/*
ENV HOME=/tmp
USER 10001:10001
ENTRYPOINT ["/usr/bin/nmap"]
