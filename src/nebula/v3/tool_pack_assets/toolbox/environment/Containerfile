FROM golang:1.26.3-bookworm@sha256:386d475a660466863d9f8c766fec64d7fdad3edac2c6a05020c09534d71edb4b AS go-builder

COPY tool-versions.env /tmp/tool-versions.env

RUN . /tmp/tool-versions.env \
    && CGO_ENABLED=0 GOTOOLCHAIN=local go install -ldflags="-s -w" "github.com/projectdiscovery/nuclei/v3/cmd/nuclei@v${NUCLEI_VERSION}"
RUN . /tmp/tool-versions.env \
    && CGO_ENABLED=0 GOTOOLCHAIN=local go install -ldflags="-s -w" "github.com/projectdiscovery/subfinder/v2/cmd/subfinder@v${SUBFINDER_VERSION}"
RUN . /tmp/tool-versions.env \
    && CGO_ENABLED=0 GOTOOLCHAIN=local go install -ldflags="-s -w" "github.com/projectdiscovery/httpx/cmd/httpx@v${HTTPX_VERSION}"
RUN . /tmp/tool-versions.env \
    && CGO_ENABLED=0 GOTOOLCHAIN=local go install -ldflags="-s -w" "github.com/projectdiscovery/dnsx/cmd/dnsx@v${DNSX_VERSION}"
RUN . /tmp/tool-versions.env \
    && CGO_ENABLED=0 GOTOOLCHAIN=local go install -ldflags="-s -w" "github.com/projectdiscovery/katana/cmd/katana@v${KATANA_VERSION}"
RUN . /tmp/tool-versions.env \
    && CGO_ENABLED=0 GOTOOLCHAIN=local go install \
      -ldflags="-s -w -X github.com/ffuf/ffuf/v2/pkg/ffuf.VERSION=${FFUF_VERSION} -X github.com/ffuf/ffuf/v2/pkg/ffuf.VERSION_APPENDIX=" \
      "github.com/ffuf/ffuf/v2@v${FFUF_VERSION}"
RUN . /tmp/tool-versions.env \
    && CGO_ENABLED=0 GOTOOLCHAIN=local go install -ldflags="-s -w" "github.com/OJ/gobuster/v3@v${GOBUSTER_VERSION}"

FROM python:3.12.12-slim-bookworm@sha256:593bd06efe90efa80dc4eee3948be7c0fde4134606dd40d8dd8dbcade98e669c AS nmap-builder

COPY tool-versions.env /tmp/tool-versions.env

RUN set -eux; \
    . /tmp/tool-versions.env; \
    rm -f /etc/apt/sources.list /etc/apt/sources.list.d/*; \
    printf '%s\n' \
      "deb [check-valid-until=no] https://snapshot.debian.org/archive/debian/${DEBIAN_SNAPSHOT} bookworm main" \
      "deb [check-valid-until=no] https://snapshot.debian.org/archive/debian/${DEBIAN_SNAPSHOT} bookworm-updates main" \
      "deb [check-valid-until=no] https://snapshot.debian.org/archive/debian-security/${DEBIAN_SNAPSHOT} bookworm-security main" \
      > /etc/apt/sources.list; \
    apt-get update; \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      "build-essential=${BUILD_ESSENTIAL_APT_VERSION}" \
      "bzip2=${BZIP2_APT_VERSION}" \
      "ca-certificates=${CA_CERTIFICATES_APT_VERSION}" \
      "curl=${CURL_APT_VERSION}" \
      "libssl-dev=${LIBSSL_DEV_APT_VERSION}"

RUN set -eux; \
    . /tmp/tool-versions.env; \
    curl -fsSL -o /tmp/nmap.tar.bz2 "https://nmap.org/dist/nmap-${NMAP_VERSION}.tar.bz2"; \
    echo "${NMAP_SHA256}  /tmp/nmap.tar.bz2" | sha256sum -c -; \
    mkdir /tmp/nmap-source; \
    tar -xjf /tmp/nmap.tar.bz2 --strip-components=1 -C /tmp/nmap-source; \
    cd /tmp/nmap-source; \
    ./configure \
      --prefix=/opt/nebula/nmap \
      --without-zenmap \
      --without-ndiff \
      --without-nping \
      --with-openssl=/usr; \
    make -j"$(nproc)"; \
    make install; \
    /opt/nebula/nmap/bin/nmap --version 2>&1 | grep -F "Nmap version ${NMAP_VERSION}"; \
    /opt/nebula/nmap/bin/ncat --version 2>&1 | grep -F "Ncat: Version ${NMAP_VERSION}"

FROM python:3.12.12-slim-bookworm@sha256:593bd06efe90efa80dc4eee3948be7c0fde4134606dd40d8dd8dbcade98e669c

COPY tool-versions.env /opt/nebula/tool-versions.env

RUN set -eux; \
    . /opt/nebula/tool-versions.env; \
    rm -f /etc/apt/sources.list /etc/apt/sources.list.d/*; \
    printf '%s\n' \
      "deb [check-valid-until=no] https://snapshot.debian.org/archive/debian/${DEBIAN_SNAPSHOT} bookworm main" \
      "deb [check-valid-until=no] https://snapshot.debian.org/archive/debian/${DEBIAN_SNAPSHOT} bookworm-updates main" \
      "deb [check-valid-until=no] https://snapshot.debian.org/archive/debian-security/${DEBIAN_SNAPSHOT} bookworm-security main" \
      > /etc/apt/sources.list; \
    apt-get update; \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      "bash=${BASH_APT_VERSION}" \
      "bsdextrautils=${BSD_EXTRAUTILS_APT_VERSION}" \
      "ca-certificates=${CA_CERTIFICATES_APT_VERSION}" \
      "curl=${CURL_APT_VERSION}" \
      "dnsutils=${DNSUTILS_APT_VERSION}" \
      "git=${GIT_APT_VERSION}" \
      "iproute2=${IPROUTE2_APT_VERSION}" \
      "iptables=${IPTABLES_APT_VERSION}" \
      "jq=${JQ_APT_VERSION}" \
      "libnet-ssleay-perl=${LIBNET_SSLEAY_PERL_APT_VERSION}" \
      "libwww-perl=${LIBWWW_PERL_APT_VERSION}" \
      "libjson-perl=${LIBJSON_PERL_APT_VERSION}" \
      "libxml-writer-perl=${LIBXML_WRITER_PERL_APT_VERSION}" \
      "openssl=${OPENSSL_APT_VERSION}" \
      "perl=${PERL_APT_VERSION}" \
      "procps=${PROCPS_APT_VERSION}" \
      "ruby=${RUBY_APT_VERSION}" \
      "ruby-addressable=${RUBY_ADDRESSABLE_APT_VERSION}" \
      "ruby-public-suffix=${RUBY_PUBLIC_SUFFIX_APT_VERSION}" \
      "socat=${SOCAT_APT_VERSION}" \
      "wget=${WGET_APT_VERSION}" \
      "whois=${WHOIS_APT_VERSION}"; \
    rm -rf /var/lib/apt/lists/* /var/cache/apt/*

RUN set -eux; \
    . /opt/nebula/tool-versions.env; \
    python -m venv /opt/nebula/venv; \
    /opt/nebula/venv/bin/pip install --no-cache-dir --disable-pip-version-check \
      "PyYAML==${PYYAML_VERSION}" \
      "jsonschema==${JSONSCHEMA_VERSION}" \
      "semgrep==${SEMGREP_VERSION}" \
      "impacket==${IMPACKET_VERSION}" \
      "sqlmap==${SQLMAP_VERSION}"; \
    /opt/nebula/venv/bin/pip check; \
    /opt/nebula/venv/bin/pip freeze --all > /opt/nebula/python-environment.lock; \
    rm -rf /root/.cache

COPY --from=go-builder /go/bin/ /usr/local/bin/
COPY --from=nmap-builder /opt/nebula/nmap/ /opt/nebula/nmap/

RUN set -eux; \
    . /opt/nebula/tool-versions.env; \
    curl -fsSL -o /tmp/nikto.tar.gz "https://github.com/sullo/nikto/archive/refs/tags/${NIKTO_VERSION}.tar.gz"; \
    echo "${NIKTO_SHA256}  /tmp/nikto.tar.gz" | sha256sum -c -; \
    mkdir -p /opt/nebula/nikto; \
    tar -xzf /tmp/nikto.tar.gz --strip-components=1 -C /opt/nebula/nikto; \
    curl -fsSL -o /tmp/whatweb.tar.gz "https://github.com/urbanadventurer/WhatWeb/archive/refs/tags/v${WHATWEB_VERSION}.tar.gz"; \
    echo "${WHATWEB_SHA256}  /tmp/whatweb.tar.gz" | sha256sum -c -; \
    mkdir -p /opt/nebula/whatweb; \
    tar -xzf /tmp/whatweb.tar.gz --strip-components=1 -C /opt/nebula/whatweb; \
    curl -fsSL -o /tmp/testssl.tar.gz "https://github.com/testssl/testssl.sh/archive/refs/tags/v${TESTSSL_VERSION}.tar.gz"; \
    echo "${TESTSSL_SHA256}  /tmp/testssl.tar.gz" | sha256sum -c -; \
    mkdir -p /opt/nebula/testssl; \
    tar -xzf /tmp/testssl.tar.gz --strip-components=1 -C /opt/nebula/testssl; \
    curl -fsSL -o /tmp/nuclei-templates.tar.gz "https://github.com/projectdiscovery/nuclei-templates/archive/refs/tags/v${NUCLEI_TEMPLATES_VERSION}.tar.gz"; \
    echo "${NUCLEI_TEMPLATES_SHA256}  /tmp/nuclei-templates.tar.gz" | sha256sum -c -; \
    mkdir -p /opt/nebula/nuclei-templates; \
    tar -xzf /tmp/nuclei-templates.tar.gz --strip-components=1 -C /opt/nebula/nuclei-templates; \
    rm -f /tmp/*.tar.gz

COPY interfaces/ /opt/nebula/interfaces/
COPY tool-catalog.schema.json /opt/nebula/tool-catalog.schema.json
COPY build-tool-catalog.py /opt/nebula/bin/build-tool-catalog
COPY nebula-toolbox.py /opt/nebula/bin/nebula-toolbox
COPY nebula-egress.py /usr/local/bin/nebula-egress

ENV HOME=/tmp \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PATH=/opt/nebula/venv/bin:/opt/nebula/nmap/bin:/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin \
    NUCLEI_TEMPLATES=/opt/nebula/nuclei-templates \
    SEMGREP_ENABLE_VERSION_CHECK=0 \
    SEMGREP_SEND_METRICS=off

RUN set -eux; \
    chmod 0555 \
      /opt/nebula/bin/build-tool-catalog \
      /opt/nebula/bin/nebula-toolbox \
      /usr/local/bin/nebula-egress; \
    /opt/nebula/bin/build-tool-catalog \
      --interfaces /opt/nebula/interfaces \
      --versions /opt/nebula/tool-versions.env \
      --schema /opt/nebula/tool-catalog.schema.json \
      --output /opt/nebula/tool-catalog.json; \
    rm -rf \
      /opt/nebula/interfaces \
      /opt/nebula/tool-catalog.schema.json \
      /opt/nebula/bin/build-tool-catalog; \
    find /tmp -mindepth 1 -maxdepth 1 -exec rm -rf -- {} +; \
    chmod 1777 /tmp; \
    chmod 0500 /usr/local/bin/nebula-egress; \
    groupadd --gid 10001 nebula; \
    useradd --uid 10001 --gid 10001 --no-create-home --home-dir /tmp --shell /usr/sbin/nologin nebula; \
    mkdir -p /workspace; \
    chown 10001:10001 /workspace; \
    chmod 0777 /workspace

WORKDIR /workspace
USER 10001:10001
