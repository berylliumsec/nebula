{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nebula.security/schemas/toolbox-catalog-v2.json",
  "title": "Nebula Toolbox exact-version interface catalog v2",
  "type": "object",
  "properties": {
    "protocol": {"const": "nebula.toolbox.catalog/v2"},
    "interface_protocol": {"const": "nebula.toolbox.interface/v2"},
    "toolbox_version": {"type": "string", "minLength": 1},
    "tools": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/tool"}},
    "inventory": {"type": "array", "items": {"$ref": "#/$defs/inventory"}}
  },
  "required": ["protocol", "interface_protocol", "toolbox_version", "tools", "inventory"],
  "additionalProperties": false,
  "$defs": {
    "example": {
      "type": "object",
      "properties": {
        "purpose": {"type": "string", "minLength": 1},
        "arguments": {"type": "array", "items": {"type": "string"}}
      },
      "required": ["purpose", "arguments"],
      "additionalProperties": false
    },
    "value": {
      "type": ["object", "null"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "type": {"enum": ["string", "integer", "number", "boolean", "path", "url", "domain", "target", "port", "duration"]},
        "required": {"type": "boolean"},
        "style": {"enum": ["separate", "equals", "attached"]},
        "enum": {"type": "array", "items": {"type": ["string", "number", "integer", "boolean"]}},
        "minimum": {"type": "number"},
        "maximum": {"type": "number"},
        "pattern": {"type": "string"},
        "default": {}
      },
      "required": ["name", "type", "required", "style"],
      "additionalProperties": false
    },
    "option": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "flags": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 2}},
        "usage": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "section": {"type": "string", "minLength": 1},
        "value": {"$ref": "#/$defs/value"},
        "repeatable": {"type": "boolean"},
        "conflicts_with": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "requires": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "implies": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
      },
      "required": ["id", "flags", "usage", "description", "section", "value", "repeatable", "conflicts_with", "requires", "implies"],
      "additionalProperties": false
    },
    "positional": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"},
        "name": {"type": "string", "minLength": 1},
        "type": {"enum": ["string", "integer", "number", "boolean", "path", "url", "domain", "target", "port", "duration"]},
        "required": {"type": "boolean"},
        "repeatable": {"type": "boolean"},
        "description": {"type": "string", "minLength": 1}
      },
      "required": ["id", "name", "type", "required", "repeatable", "description"],
      "additionalProperties": false
    },
    "helpDocument": {
      "type": "object",
      "properties": {
        "command_path": {"type": "array", "items": {"type": "string"}},
        "argv": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "exit_code": {"type": "integer"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "text": {"type": "string", "minLength": 1}
      },
      "required": ["command_path", "argv", "exit_code", "sha256", "text"],
      "additionalProperties": false
    },
    "command": {
      "type": "object",
      "properties": {
        "path": {"type": "array", "items": {"type": "string"}},
        "synopsis": {"type": "string", "minLength": 1},
        "positionals": {"type": "array", "items": {"$ref": "#/$defs/positional"}},
        "options": {"type": "array", "items": {"$ref": "#/$defs/option"}},
        "help_documents": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/helpDocument"}}
      },
      "required": ["path", "synopsis", "positionals", "options", "help_documents"],
      "additionalProperties": false
    },
    "coverage": {
      "type": "object",
      "properties": {
        "help_documents": {"type": "integer", "minimum": 1},
        "documented_options": {"type": "integer", "minimum": 0},
        "structured_options": {"type": "integer", "minimum": 0},
        "unmapped_options": {"type": "array", "maxItems": 0},
        "complete": {"const": true}
      },
      "required": ["help_documents", "documented_options", "structured_options", "unmapped_options", "complete"],
      "additionalProperties": false
    },
    "tool": {
      "type": "object",
      "properties": {
        "protocol": {"const": "nebula.toolbox.interface/v2"},
        "name": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"},
        "version": {"type": "string", "minLength": 1},
        "package_version": {"type": "string", "minLength": 1},
        "executable": {"type": "string", "pattern": "^/"},
        "aliases": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "category": {"type": "string", "minLength": 1},
        "risk_class": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "homepage": {"type": "string", "format": "uri"},
        "synopsis": {"type": "string", "minLength": 1},
        "examples": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/example"}},
        "notes": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "commands": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/command"}},
        "coverage": {"$ref": "#/$defs/coverage"}
      },
      "required": ["protocol", "name", "version", "executable", "aliases", "category", "risk_class", "description", "homepage", "synopsis", "examples", "notes", "commands", "coverage"],
      "additionalProperties": false
    },
    "inventory": {
      "type": "object",
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "path": {"type": "string", "pattern": "^/"},
        "catalogued": {"type": "boolean"},
        "interface": {"type": ["string", "null"]},
        "aliases": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
      },
      "required": ["name", "path", "catalogued", "interface", "aliases"],
      "additionalProperties": false
    }
  }
}
