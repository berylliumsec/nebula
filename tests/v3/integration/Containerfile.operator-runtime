FROM python:3.12.12-slim-bookworm@sha256:593bd06efe90efa80dc4eee3948be7c0fde4134606dd40d8dd8dbcade98e669c

RUN mkdir -p /opt/nebula/bin /opt/nebula/venv/bin /workspace \
    && ln -s /usr/local/bin/python /opt/nebula/venv/bin/python \
    && chmod 0777 /workspace /tmp

COPY src/nebula/v3/tool_pack_assets/toolbox/environment/nebula-toolbox.py /opt/nebula/bin/nebula-toolbox
RUN chmod 0555 /opt/nebula/bin/nebula-toolbox

WORKDIR /workspace
USER 65532:65532
