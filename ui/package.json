{
  "name": "nebula-ui",
  "private": true,
  "version": "3.0.0-alpha.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "npm run build && npm run build:core && npm run dev",
    "build": "tsc -b && vite build",
    "build:core": "poetry -C .. run python -m scripts.build_nebula_core",
